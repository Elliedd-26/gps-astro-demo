---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

interface Props {
  event: CollectionEntry<'events'>;
}

const { event } = Astro.props;
const { Content } = await event.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---
<BaseLayout title={event.data.title}>
  <article class="event-detail fade-up">
    <a href="/" class="back-link">← Back to events · 返回活动列表</a>

    <figure class="event-cover">
      <img
        src={event.data.cover_image}
        alt={event.data.photo_caption ?? `Cover image for ${event.data.title}`}
        width="1600"
        height="900"
      />
      {(event.data.photo_caption || event.data.photo_caption_zh) && (
        <figcaption class="event-cover-caption">
          {event.data.photo_caption && <span>{event.data.photo_caption}</span>}
          {event.data.photo_caption_zh && (
            <span class="zh"> · {event.data.photo_caption_zh}</span>
          )}
        </figcaption>
      )}
    </figure>

    <header class="event-header">
      <h1>{event.data.title}</h1>
      <h2 class="event-title-zh">{event.data.title_zh}</h2>
      <div class="event-meta">
        <span>{formatDate(event.data.date)}</span>
        <span class="event-sep">·</span>
        <span>{event.data.location}</span>
        <span class="event-sep">·</span>
        <span>Hosted by {event.data.host}</span>
      </div>
    </header>

    <div class="event-body prose">
      <Content />
    </div>
  </article>
</BaseLayout>
