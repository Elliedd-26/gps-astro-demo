---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const events = await getCollection('events');
const sortedEvents = events.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---
<BaseLayout title="Events">
  <section class="hero">
    <h1>GPS · Gal Pal Society</h1>
    <p class="hero-sub">
      Toronto community for Chinese-speaking queer women · 多伦多华语 queer 女性社区
    </p>
  </section>

  <section class="section">
    <h2 class="section-heading">Recent Events <span class="section-heading-zh">· 近期活动</span></h2>

    <div class="events-grid">
      {sortedEvents.map((event) => (
        <a href={`/events/${event.slug}`} class="event-card fade-up">
          <div class="event-card-cover">
            <img
              src={event.data.cover_image}
              alt={`Cover image for ${event.data.title}`}
              loading="lazy"
              width="1600"
              height="900"
            />
          </div>
          <div class="event-card-body">
            <div class="event-card-title">{event.data.title}</div>
            <div class="event-card-title-zh">{event.data.title_zh}</div>
            <div class="event-card-meta">
              <span>{formatDate(event.data.date)}</span>
              <span class="event-sep">·</span>
              <span>{event.data.location}</span>
            </div>
            {event.data.description && (
              <p class="event-card-desc">{event.data.description}</p>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
